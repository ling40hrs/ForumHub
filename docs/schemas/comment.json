{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ling40hrs/ForumHub/docs/schemas/comment.json",
  "title": "Comment",
  "type": "object",
  "properties": {
    "id":         { "type": "integer" },
    "body":       { "type": "string" },
    "user_id":    { "type": "integer" },
    "username":   { "type": "string" },
    "post_id":    { "type": "integer" },
    "parent_id":  { "type": ["integer", "null"] },
    "score":      { "type": "integer" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "body", "user_id", "post_id", "score", "created_at"]
}
