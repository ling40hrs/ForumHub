#!/usr/bin/env bash
set -euo pipefail

echo "=== Yapr Setup ==="
echo ""

# ── Backend ──
echo "→ Installing PHP dependencies..."
cd "$(dirname "$0")/../backend"
composer install --quiet

if [ ! -f .env ]; then
    cp .env.example .env
    echo "  Created .env from .env.example — edit database credentials."
fi

cd - > /dev/null

echo "=== Setup complete ==="
echo ""
echo "Start development:"
echo "  Backend:  cd backend && php -S localhost:8000 -t public"
echo "  Frontend: php -S localhost:8000 -t public router.php"
echo "  Database: mysql -u root -p < database/schema.sql"
